#include <CAN.h> // the OBD2 library depends on the CAN library
#include <OBD2.h>

#define Serial Serial0

// array of PID's to print values of
// const int PIDS[] = {
//   // CALCULATED_ENGINE_LOAD,
//   // ENGINE_COOLANT_TEMPERATURE,
//   // ENGINE_RPM,
//   // VEHICLE_SPEED,
//   // AIR_INTAKE_TEMPERATURE,
//   MAF_AIR_FLOW_RATE,
//   // THROTTLE_POSITION,
//   // RUN_TIME_SINCE_ENGINE_START,
//   // FUEL_TANK_LEVEL_INPUT,
//   // ABSOLULTE_BAROMETRIC_PRESSURE,
//   // ABSOLUTE_LOAD_VALUE,
//   // RELATIVE_THROTTLE_POSITION
// };
int PIDS[96];
int NUM_PIDS = 0;

void printPID(int pid);

void setup() {
  Serial0.begin(115200);
  while (!Serial0);

  Serial0.println(F("OBD2 Key Stats"));

  while (true) {
    Serial0.print(F("Attempting to connect to OBD2 CAN bus ... "));

    if (!OBD2.begin()) {
      Serial0.println(F("failed!"));

      delay(1000);
    } else {
      Serial0.println(F("success"));
      break;
    }
  }
     // loop through PIDs 0 to 95, reading and printing the names of the supported PIDs
  int index = 0;
  for (int pid = 0; pid < 96; pid++) {
    if (OBD2.pidSupported(pid)) {
      PIDS[index] = pid;
      index++;
      Serial0.println(OBD2.pidName(pid));
    }
  }
  NUM_PIDS = index-1;
  Serial0.printf("Number of PIDs: %d\n", NUM_PIDS);  
  Serial0.println();
  for (int i = 0; i < NUM_PIDS; i++) {
    int pid = PIDS[i];

    printPID(pid);
  }
  Serial0.println();
  std::string dtcs[20];  // Buffer for up to 20 DTCs
  int dtcCount = OBD2.dtcRead(dtcs, 20);
  for (int i = 0; i < dtcCount; i++) {
    Serial0.println(dtcs[i].c_str());
  }
}

void loop() {
  // loop through all the PID's in the array
  // 
  // for (int i = 0; i < NUM_PIDS; i++) {
  //   int pid = PIDS[i];

  //   printPID(pid);
  // }
  // Serial0.println();

  delay(1000);
}

void printPID(int pid) {
  // print PID name
  Serial0.print(OBD2.pidName(pid));
  Serial0.print(F(" = "));

  // read the PID value
  float pidValue = OBD2.pidRead(pid);

  if (isnan(pidValue)) {
    Serial0.print("error");
  } else {
    // print value with units
    Serial0.print(pidValue);
    Serial0.print(F(" "));
    Serial0.print(OBD2.pidUnits(pid));
  }

  Serial0.println();
}