Checks: >
  -*,
  bugprone-*,
  readability-*,
  performance-*,
  portability-*,
  cppcoreguidelines-*

WarningsAsErrors: 
  - bugprone-*
  - portability-*

CheckOptions:
  - key: readability-identifier-naming.VariableCase
    value: lower_case
  - key: readability-identifier-naming.FunctionCase
    value: CamelCase
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
